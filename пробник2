<script>
let chartData = [];
let currentHistoryPeriod = 0;
let currentHistoryLimit = 20;
let currentChartPeriod = 0;
let currentChartLimit = 20;
let visibleMetrics = { temp: true, hum: true, soil: true, pressure: true };
let currentChartMode = 'all';
let serverTimeOffset = 0;
let historyCustomStart = 0, historyCustomEnd = 0;
let chartCustomStart = 0, chartCustomEnd = 0;
const UPDATE_INTERVAL = 10000;
let plantConfig = null;

document.addEventListener('DOMContentLoaded', () => {
  initTheme(); initTabs(); initHistoryFilters(); initChartFilters(); initLegend(); initClearButton();
  initHistoryCustomRange(); initChartCustomRange(); initChart();
  syncTimeWithServer(); startAutoUpdate();
  
  loadPlantConfig().then(() => { loadData(); });
  
  document.querySelectorAll('.plant-option').forEach(opt => {
    opt.addEventListener('click', (e) => {
      if(e.target.closest('.btn-delete')) return;
      document.querySelectorAll('.plant-option').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      savePlantConfig({
        name: opt.dataset.name,
        displayName: opt.querySelector('strong').textContent,
        temp: opt.dataset.temp.split(',').map(Number),
        hum: opt.dataset.hum.split(',').map(Number),
        soil: opt.dataset.soil.split(',').map(Number),
        press: opt.dataset.press.split(',').map(Number)
      });
    });
  });
  document.querySelectorAll('.btn-delete').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const opt = btn.closest('.plant-option');
      opt.style.opacity = '0.3'; opt.style.pointerEvents = 'none'; opt.dataset.deleted = '1';
      if(document.querySelector('.plant-option.selected') === opt) opt.classList.remove('selected');
    });
  });
  document.getElementById('savePlantBtn').addEventListener('click', saveCustomPlant);
  document.getElementById('changePlantBtn').addEventListener('click', () => {
    document.getElementById('setupView').style.display = 'flex';
    prefillPlantForm();
  });
});

async function loadPlantConfig() {
  try {
    const res = await fetch('/plant/load?t=' + Date.now());
    const cfg = await res.json();
    if (cfg && cfg.name) {
      plantConfig = cfg;
      document.getElementById('setupView').style.display = 'none';
    } else {
      document.getElementById('setupView').style.display = 'flex';
    }
  } catch(e) { document.getElementById('setupView').style.display = 'flex'; }
}

function prefillPlantForm() {
  document.querySelectorAll('.plant-option').forEach(o => o.classList.remove('selected'));
  if (plantConfig) {
    if (plantConfig.name !== 'Custom') {
      const preset = document.querySelector(`.plant-option[data-name="${plantConfig.name}"]`);
      if(preset && !preset.dataset.deleted) preset.classList.add('selected');
    } else {
      document.getElementById('custTempMin').value = plantConfig.temp[0];
      document.getElementById('custTempMax').value = plantConfig.temp[1];
      document.getElementById('custHumMin').value = plantConfig.hum[0];
      document.getElementById('custHumMax').value = plantConfig.hum[1];
      document.getElementById('custSoilMin').value = plantConfig.soil[0];
      document.getElementById('custSoilMax').value = plantConfig.soil[1];
      document.getElementById('custPresMin').value = plantConfig.press[0];
      document.getElementById('custPresMax').value = plantConfig.press[1];
    }
  }
}

function saveCustomPlant() {
  const v = id => { let x = parseFloat(document.getElementById(id).value); return isNaN(x) ? -1 : x; };
  const tMin=v('custTempMin'), tMax=v('custTempMax'), hMin=v('custHumMin'), hMax=v('custHumMax');
  const sMin=v('custSoilMin'), sMax=v('custSoilMax'), pMin=v('custPresMin'), pMax=v('custPresMax');
  
  const check = (mn, mx, name) => {
    if(mn<0||mx<0) return `${name}: значения не могут быть отрицательными`;
    if(mn>=mx) return `${name}: мин. должно быть строго меньше макс.`;
    return null;
  };
  const err = check(tMin,tMax,'Температура')||check(hMin,hMax,'Влажность')||check(sMin,sMax,'Почва')||check(pMin,pMax,'Давление');
  if(err) { alert(err); return; }
  
  savePlantConfig({ name:'Custom', displayName:'Своё растение', temp:[tMin,tMax], hum:[hMin,hMax], soil:[sMin,sMax], press:[pMin,pMax] });
}

function savePlantConfig(cfg) {
  const btn = document.getElementById('savePlantBtn');
  btn.disabled = true; btn.textContent = 'Сохранение...';
  fetch('/plant/save', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(cfg) })
  .then(()=>{
    plantConfig = cfg;
    document.getElementById('setupView').style.display = 'none';
    loadData();
  }).catch(()=>alert('Ошибка сохранения')).finally(()=>{ btn.disabled=false; btn.textContent='Сохранить и продолжить'; });
}

async function syncTimeWithServer() { /* ... без изменений ... */ try{const res=await fetch('/time?t='+Date.now());const s=await res.text();const now=new Date();if(s&&!s.startsWith('UP')){const p=s.split(' ');if(p.length>=2){const[d,t]=p;const[day,m,y]=d.split('.');const[h,mi,sc]=t.split(':');const sd=new Date('20'+y+'-'+m+'-'+day+'T'+h+':'+mi+':'+sc);serverTimeOffset=sd.getTime()-now.getTime();document.getElementById('timeStatus').textContent=s;document.getElementById('syncStatus').className='sync-status';}}else{document.getElementById('syncStatus').className='sync-status error';}}catch(e){document.getElementById('syncStatus').className='sync-status error';}}
function initTheme() { const s=localStorage.getItem('theme'); if(s==='dark') document.documentElement.setAttribute('data-theme','dark'); document.getElementById('themeBtn').addEventListener('click',()=>{const h=document.documentElement;const d=h.getAttribute('data-theme')==='dark';if(d){h.removeAttribute('data-theme');localStorage.setItem('theme','light');}else{h.setAttribute('data-theme','dark');localStorage.setItem('theme','dark');}if(document.getElementById('tab-charts').classList.contains('active'))drawChart();}); }
function initTabs() { document.querySelectorAll('.tab').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));document.querySelectorAll('.content').forEach(x=>x.classList.remove('active'));b.classList.add('active');document.getElementById('tab-'+b.dataset.tab).classList.add('active');if(b.dataset.tab==='charts')setTimeout(drawChart,100);});}); }
function initHistoryFilters() { document.querySelectorAll('.history-panel .filter-btn[data-period]').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.history-panel .filter-btn[data-period]').forEach(x=>x.classList.remove('active'));b.classList.add('active');currentHistoryPeriod=parseInt(b.dataset.period);currentHistoryLimit=parseInt(b.dataset.limit);historyCustomStart=0;historyCustomEnd=0;document.getElementById('historyCustomRange').style.display='none';loadHistory();});}); }
function initChartFilters() { document.querySelectorAll('.chart-panel .chart-filter[data-period]').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.chart-panel .chart-filter[data-period]').forEach(x=>x.classList.remove('active'));b.classList.add('active');currentChartPeriod=parseInt(b.dataset.period);currentChartLimit=parseInt(b.dataset.limit);chartCustomStart=0;chartCustomEnd=0;document.getElementById('chartCustomRange').style.display='none';loadChartData();});}); }
function initHistoryCustomRange() { document.getElementById('historyDateBtn').addEventListener('click',()=>{document.querySelectorAll('.history-panel .filter-btn[data-period]').forEach(b=>b.classList.remove('active'));document.getElementById('historyDateBtn').classList.add('active');document.getElementById('historyCustomRange').style.display='flex';const n=new Date();n.setMinutes(n.getMinutes()-n.getTimezoneOffset());document.getElementById('historyEndDate').value=n.toISOString().slice(0,16);const y=new Date(n.getTime()-24*60*60*1000);document.getElementById('historyStartDate').value=y.toISOString().slice(0,16);}); document.getElementById('historyApplyBtn').addEventListener('click',()=>{const s=document.getElementById('historyStartDate').value,e=document.getElementById('historyEndDate').value;if(s&&e){historyCustomStart=Math.floor(new Date(s).getTime()/1000);historyCustomEnd=Math.floor(new Date(e).getTime()/1000);currentHistoryPeriod=0;currentHistoryLimit=0;loadHistory();document.getElementById('historyCustomRange').style.display='none';}}); document.getElementById('historyCancelBtn').addEventListener('click',()=>{document.getElementById('historyCustomRange').style.display='none';document.querySelectorAll('.history-panel .filter-btn[data-period]').forEach(b=>b.classList.remove('active'));document.querySelector('.history-panel .filter-btn[data-period="0"]').classList.add('active');currentHistoryPeriod=0;currentHistoryLimit=20;historyCustomStart=0;historyCustomEnd=0;loadHistory();}); }
function initChartCustomRange() { document.getElementById('chartDateBtn').addEventListener('click',()=>{document.querySelectorAll('.chart-panel .chart-filter[data-period]').forEach(b=>b.classList.remove('active'));document.getElementById('chartDateBtn').classList.add('active');document.getElementById('chartCustomRange').style.display='flex';const n=new Date();n.setMinutes(n.getMinutes()-n.getTimezoneOffset());document.getElementById('chartEndDate').value=n.toISOString().slice(0,16);const y=new Date(n.getTime()-24*60*60*1000);document.getElementById('chartStartDate').value=y.toISOString().slice(0,16);}); document.getElementById('chartApplyBtn').addEventListener('click',()=>{const s=document.getElementById('chartStartDate').value,e=document.getElementById('chartEndDate').value;if(s&&e){chartCustomStart=Math.floor(new Date(s).getTime()/1000);chartCustomEnd=Math.floor(new Date(e).getTime()/1000);currentChartPeriod=0;currentChartLimit=0;loadChartData();document.getElementById('chartCustomRange').style.display='none';}}); document.getElementById('chartCancelBtn').addEventListener('click',()=>{document.getElementById('chartCustomRange').style.display='none';document.querySelectorAll('.chart-panel .chart-filter[data-period]').forEach(b=>b.classList.remove('active'));document.querySelector('.chart-panel .chart-filter[data-period="0"]').classList.add('active');currentChartPeriod=0;currentChartLimit=20;chartCustomStart=0;chartCustomEnd=0;loadChartData();}); }
function initLegend() { document.querySelectorAll('.legend-item').forEach(i=>{i.addEventListener('click',()=>{document.querySelectorAll('.legend-item').forEach(x=>x.classList.remove('active'));i.classList.add('active');const m=i.dataset.metric;if(m==='all'){currentChartMode='all';visibleMetrics={temp:true,hum:true,soil:true,pressure:true};document.getElementById('chartModeIndicator').classList.remove('visible');document.getElementById('yAxisLabel').style.display='none';document.getElementById('yAxisValues').innerHTML='';}else{currentChartMode=m;visibleMetrics={temp:false,hum:false,soil:false,pressure:false};visibleMetrics[m]=true;document.getElementById('chartModeIndicator').classList.add('visible');const l={temp:'°C',hum:'%',soil:'%',pressure:'мм'};const el=document.getElementById('yAxisLabel');el.textContent=l[m]||'';el.style.color=getMetricStyle(m).color;el.style.display='block';}drawChart();});}); }
function initClearButton() { document.getElementById('clearBtn').addEventListener('click', async()=>{if(!confirm('Удалить всю историю измерений?')) return;try{await fetch('/clear',{method:'POST'});loadHistory();if(document.getElementById('tab-charts').classList.contains('active'))loadChartData();}catch(e){alert('Ошибка при очистке');}}); }
async function loadData() { await Promise.all([fetchMetrics(), loadHistory()]); if(document.getElementById('tab-charts').classList.contains('active')) await loadChartData(); }
async function fetchMetrics() { try{const r=await fetch('/data?t='+Date.now());updateMetrics(await r.json());syncTimeWithServer();}catch(e){console.log('Ошибка загрузки показателей');} }

// === ОБНОВЛЕНИЕ МЕТРИК С ПОДСВЕТКОЙ ОТКЛОНЕНИЙ ===
function updateMetrics(d) {
  const list = [
    { id:'temp', key:'temp', unit:'°C', range:plantConfig?.temp },
    { id:'hum', key:'humidity', unit:'%', range:plantConfig?.hum },
    { id:'soil', key:'soil', unit:'%', range:plantConfig?.soil },
    { id:'pressure', key:'pressure', unit:'мм рт.ст.', range:plantConfig?.press }
  ];
  list.forEach(m => {
    const el = document.getElementById(m.id);
    const val = d[m.key];
    el.textContent = val ?? '--';
    const card = el.parentElement;
    card.classList.remove('metric-alert');
    el.classList.remove('value-red');
    if (plantConfig && val !== null && m.range) {
      if (val < m.range[0] || val > m.range[1]) {
        card.classList.add('metric-alert');
        el.classList.add('value-red');
      }
    }
  });
}
// ================================================

async function loadHistory() { const l=document.getElementById('historyList');l.innerHTML='<div class="loading">Загрузка...</div>';try{let u='/hist?period='+currentHistoryPeriod+'&limit='+currentHistoryLimit;if(historyCustomStart>0&&historyCustomEnd>0)u+='&start='+historyCustomStart+'&end='+historyCustomEnd;u+='&t='+Date.now();const r=await fetch(u);chartData=await r.json();renderHistory(chartData);}catch(e){l.innerHTML='<div class="history-empty">Ошибка загрузки</div>';}}
function renderHistory(data) { const l=document.getElementById('historyList');if(!data||data.length===0){l.innerHTML='<div class="history-empty">Нет данных за выбранный период</div>';return;}let h='';data.slice().reverse().forEach(i=>{let t=i.time||'--:--:--';h+='<div class="history-item"><span class="history-time">'+t+'</span><div class="history-values"><span class="val-temp">T:'+(i.temp!=null?i.temp:'-')+'°C</span><span class="val-hum">H:'+(i.hum!=null?i.hum:'-')+'%</span><span class="val-soil">S:'+(i.soil!=null?i.soil:'-')+'%</span><span class="val-press">P:'+(i.pressure!=null?i.pressure:'-')+'мм</span></div></div>';});l.innerHTML=h;}
async function loadChartData() { try{let u='/hist?period='+currentChartPeriod+'&limit='+currentChartLimit;if(chartCustomStart>0&&chartCustomEnd>0)u+='&start='+chartCustomStart+'&end='+chartCustomEnd;u+='&t='+Date.now();const r=await fetch(u);chartData=await r.json();drawChart();}catch(e){console.log('Ошибка загрузки графика');}}
let chartCtx,chartCanvas;function initChart(){chartCanvas=document.getElementById('chart');chartCtx=chartCanvas.getContext('2d');chartCanvas.addEventListener('mousemove',handleChartHover);chartCanvas.addEventListener('mouseleave',hideTooltip);chartCanvas.addEventListener('touchmove',(e)=>{e.preventDefault();handleChartHover(e);},{passive:false});window.addEventListener('resize',()=>{if(document.getElementById('tab-charts').classList.contains('active'))drawChart();});}
function drawChart(){if(!chartCtx||!chartData||chartData.length<2){drawEmptyChart();return;}const dpr=window.devicePixelRatio||1;const rect=chartCanvas.getBoundingClientRect();chartCanvas.width=rect.width*dpr;chartCanvas.height=rect.height*dpr;chartCtx.scale(dpr,dpr);const W=rect.width,H=rect.height;const P={t:25,r:40,b:40,l:45};const cW=W-P.l-P.r,cH=H-P.t-P.b;chartCtx.clearRect(0,0,W,H);const active=currentChartMode==='all'?Object.keys(visibleMetrics).filter(k=>visibleMetrics[k]):[currentChartMode];if(active.length===0){drawEmptyChart();return;}const ranges=calculateRanges(chartData,active);drawGrid(P,cW,cH,ranges,W,H,active);drawYAxisValues(P,cH,ranges,active);const lines={};active.forEach(k=>{lines[k]=drawLine(chartData,k,ranges[k],P,cW,cH,getMetricStyle(k));});chartCanvas._lines=lines;chartCanvas._params={P,cW,cH,ranges,active};}
function calculateRanges(data,active){const ranges={};const info={temp:{key:'temp',defaultMin:10,defaultMax:35},hum:{key:'hum',defaultMin:0,defaultMax:100},soil:{key:'soil',defaultMin:0,defaultMax:100},pressure:{key:'pressure',defaultMin:740,defaultMax:770}};active.forEach(m=>{const i=info[m];let mn=Infinity,mx=-Infinity;data.forEach(d=>{const v=d[i.key];if(v!=null){mn=Math.min(mn,v);mx=Math.max(mx,v);}});if(mn===Infinity){mn=i.defaultMin;mx=i.defaultMax;}if(mn===mx){mn-=1;mx+=1;}const p=(mx-mn)*0.1;ranges[m]={min:mn-p,max:mx+p,key:i.key};});return ranges;}
function getMetricStyle(k){const s={temp:{color:'#ef4444',width:2.5},hum:{color:'#3b82f6',width:2.5},soil:{color:'#22c55e',width:2.5},pressure:{color:'#a855f7',width:2,dash:[5,3]}};return s[k]||{color:'#6b7280',width:2};}
function drawGrid(P,cW,cH,ranges,W,H,active){const ctx=chartCtx;const gc=getComputedStyle(document.body).getPropertyValue('--border').trim();const tc=getComputedStyle(document.body).getPropertyValue('--text2').trim();const tp=getComputedStyle(document.body).getPropertyValue('--text').trim();ctx.strokeStyle=gc;ctx.lineWidth=1;ctx.font='10px sans-serif';ctx.fillStyle=tc;ctx.textAlign='right';for(let i=0;i<=4;i++){const y=P.t+(cH/4)*i;ctx.beginPath();ctx.moveTo(P.l,y);ctx.lineTo(W-P.r,y);ctx.stroke();}ctx.textAlign='center';ctx.fillStyle=tc;const step=Math.max(1,Math.floor(chartData.length/6));for(let i=0;i<chartData.length;i+=step){const x=P.l+(cW/Math.max(1,chartData.length-1))*i;const ts=chartData[i].time||'';const tp=ts.split(' ');const to=tp.length>1?tp[1]:ts;const[hh,mm]=to.split(':');const lbl=hh&&mm?hh+':'+mm:to;ctx.fillText(lbl,x,P.t+cH+18);}ctx.fillStyle=tp;ctx.fillText('Время',W/2,H-5);ctx.strokeStyle=gc;ctx.beginPath();ctx.moveTo(P.l,P.t+cH);ctx.lineTo(W-P.r,P.t+cH);ctx.stroke();}
function drawYAxisValues(P,cH,ranges,active){const c=document.getElementById('yAxisValues');const l=document.getElementById('yAxisLabel');if(!c||active.length===0){if(c)c.innerHTML='';return;}if(currentChartMode==='all'){c.innerHTML='';l.style.display='none';return;}const f=active[0];const r=ranges[f];let h='';for(let i=0;i<=4;i++){const v=Math.round(r.max-(r.max-r.min)*(i/4));h+='<div class="y-axis-value">'+v+'</div>';}c.innerHTML=h;}
