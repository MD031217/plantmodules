<script>
let chartData = [];
let currentHistoryPeriod = 0;
let currentHistoryLimit = 20;
let currentChartPeriod = 0;
let currentChartLimit = 20;
let visibleMetrics = { temp: true, hum: true, soil: true, pressure: true };
let currentChartMode = 'all';
let serverTimeOffset = 0;
let historyCustomStart = 0, historyCustomEnd = 0;
let chartCustomStart = 0, chartCustomEnd = 0;
const UPDATE_INTERVAL = 10000;

// === ДОБАВЛЕНО: Логика конфигурации растения ===
let plantConfig = null;

document.addEventListener('DOMContentLoaded', () => {
  initTheme();
  initTabs();
  initHistoryFilters();
  initChartFilters();
  initLegend();
  initClearButton();
  initHistoryCustomRange();
  initChartCustomRange();
  initChart();
  syncTimeWithServer();
  startAutoUpdate();
  
  // Загружаем конфиг растения перед основной ладой
  loadPlantConfig().then(() => {
    loadData();
  });
  
  // Обработчики стартовой страницы
  document.querySelectorAll('.plant-option').forEach(opt => {
    opt.addEventListener('click', (e) => {
      if(e.target.classList.contains('btn-delete')) return;
      document.querySelectorAll('.plant-option').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
    });
  });
  document.querySelectorAll('.btn-delete').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const opt = btn.closest('.plant-option');
      opt.style.opacity = '0.3'; opt.style.pointerEvents = 'none';
      opt.dataset.deleted = '1';
      if(document.querySelector('.plant-option.selected') === opt) opt.classList.remove('selected');
    });
  });
  document.getElementById('savePlantBtn').addEventListener('click', savePlant);
});

async function loadPlantConfig() {
  try {
    const res = await fetch('/plant/load?t=' + Date.now());
    const cfg = await res.json();
    if (cfg && cfg.name) {
      plantConfig = cfg;
      document.getElementById('setupView').style.display = 'none';
    }
  } catch(e) { console.warn('Config load failed'); }
}

async function savePlant() {
  let cfg = null;
  const selected = document.querySelector('.plant-option.selected');
  if (selected && !selected.dataset.deleted) {
    cfg = {
      name: selected.dataset.name,
      displayName: selected.querySelector('strong').textContent,
      temp: selected.dataset.temp.split(',').map(Number),
      hum: selected.dataset.hum.split(',').map(Number),
      soil: selected.dataset.soil.split(',').map(Number),
      press: selected.dataset.press.split(',').map(Number)
    };
  } else {
    const parse = id => parseInt(document.getElementById(id).value);
    const tMin = parse('custTempMin'), tMax = parse('custTempMax');
    if (isNaN(tMin) || isNaN(tMax) || tMin >= tMax) { alert('Укажите корректный диапазон температур'); return; }
    
    cfg = {
      name: "Custom",
      displayName: "Своё растение",
      temp: [tMin, tMax],
      hum: [parse('custHumMin'), parse('custHumMax')].some(isNaN) ? [30,70] : [parse('custHumMin'), parse('custHumMax')],
      soil: [parse('custSoilMin'), parse('custSoilMax')].some(isNaN) ? [20,80] : [parse('custSoilMin'), parse('custSoilMax')],
      press: [parse('custPresMin'), parse('custPresMax')].some(isNaN) ? [740,770] : [parse('custPresMin'), parse('custPresMax')]
    };
  }

  const btn = document.getElementById('savePlantBtn');
  btn.disabled = true; btn.textContent = 'Сохранение...';
  try {
    await fetch('/plant/save', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(cfg)
    });
    plantConfig = cfg;
    document.getElementById('setupView').style.display = 'none';
    loadData();
  } catch(e) { alert('Ошибка сохранения'); }
  finally { btn.disabled = false; btn.textContent = 'Сохранить и продолжить'; }
}
