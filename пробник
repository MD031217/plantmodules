async function loadData() {
await Promise.all([fetchMetrics(), loadHistory()]);
if (document.getElementById('tab-charts').classList.contains('active')) await loadChartData();
}
async function fetchMetrics() {
try {
const res = await fetch('/data?t=' + Date.now());
const data = await res.json();
updateMetrics(data);
syncTimeWithServer();
} catch (e) { console.log('Ошибка загрузки показателей'); }
}

// === ДОБАВЛЕНО: Обновление метрик с проверкой отклонений ===
function updateMetrics(d) {
  const metrics = [
    { id: 'temp', key: 'temp', unit: '°C', range: plantConfig?.temp },
    { id: 'hum', key: 'humidity', unit: '%', range: plantConfig?.hum },
    { id: 'soil', key: 'soil', unit: '%', range: plantConfig?.soil },
    { id: 'pressure', key: 'pressure', unit: 'мм рт.ст.', range: plantConfig?.press }
  ];

  metrics.forEach(m => {
    const el = document.getElementById(m.id);
    const val = d[m.key];
    el.textContent = val ?? '--';
    const parent = el.parentElement;
    parent.classList.remove('metric-alert');
    el.classList.remove('value-red');
    
    if (plantConfig && val !== null && m.range) {
      if (val < m.range[0] || val > m.range[1]) {
        parent.classList.add('metric-alert');
        el.classList.add('value-red');
      }
    }
  });
}
