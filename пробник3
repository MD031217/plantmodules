void handleAuthRegister() {
  if (server.method() != HTTP_POST) { server.send(405, "text/plain", "Method not allowed"); return; }
  DynamicJsonDocument doc(256);
  if (deserializeJson(doc, server.arg("plain")) || !doc["username"] || !doc["password"]) { server.send(400, "text/plain", "Invalid"); return; }
  String u = doc["username"].as<String>(), p = doc["password"].as<String>();
  
  DynamicJsonDocument usersDoc(1024);
  File f = LittleFS.open(USERS_FILE, "r");
  if (f) { deserializeJson(usersDoc, f); f.close(); } else { usersDoc["users"] = JsonArray(); }
  
  JsonArray users = usersDoc["users"].as<JsonArray>();
  for (JsonObject usr : users) if (usr["username"].as<String>() == u) { server.send(409, "text/plain", "Exists"); return; }
  
  JsonObject nu = users.add<JsonObject>(); nu["username"] = u; nu["password"] = p;
  f = LittleFS.open(USERS_FILE, "w"); serializeJson(usersDoc, f); f.close();
  server.send(200, "text/plain", "OK");
}

void handleAuthLogin() {
  if (server.method() != HTTP_POST) { server.send(405, "text/plain", "Method not allowed"); return; }
  DynamicJsonDocument doc(256);
  if (deserializeJson(doc, server.arg("plain"))) { server.send(400, "text/plain", "Invalid"); return; }
  String u = doc["username"].as<String>(), p = doc["password"].as<String>();
  
  File f = LittleFS.open(USERS_FILE, "r");
  if (!f) { server.send(401, "text/plain", "No users"); return; }
  DynamicJsonDocument usersDoc(1024); deserializeJson(usersDoc, f); f.close();
  
  for (JsonObject usr : usersDoc["users"].as<JsonArray>()) {
    if (usr["username"].as<String>() == u && usr["password"].as<String>() == p) { server.send(200, "text/plain", "OK"); return; }
  }
  server.send(401, "text/plain", "Bad credentials");
}

void handlePlantsLoad() {
  preSeedPlants();
  if (!LittleFS.exists(PLANTS_FILE)) { server.send(200, "application/json", "[]"); return; }
  File f = LittleFS.open(PLANTS_FILE, "r");
  DynamicJsonDocument doc(4096);
  if (f) { deserializeJson(doc, f); f.close(); }
  String out; serializeJson(doc, out);
  server.send(200, "application/json", out);
}

void handlePlantsSave() {
  if (server.method() != HTTP_POST) { server.send(405, "text/plain", "Method not allowed"); return; }
  DynamicJsonDocument newPlantDoc(512);
  if (deserializeJson(newPlantDoc, server.arg("plain"))) { server.send(400, "text/plain", "Invalid JSON"); return; }
  String newName = newPlantDoc["name"].as<String>();
  if (newName.isEmpty()) { server.send(400, "text/plain", "Missing name"); return; }

  DynamicJsonDocument plantsDoc(4096);
  File f = LittleFS.open(PLANTS_FILE, "r");
  if (f) { deserializeJson(plantsDoc, f); f.close(); }
  
  JsonArray arr = plantsDoc.as<JsonArray>();
  if (!arr) arr = plantsDoc.to<JsonArray>();

  for (JsonObject p : arr) if (p["name"].as<String>() == newName) { server.send(409, "text/plain", "Name taken"); return; }

  arr.add(newPlantDoc.as<JsonObject>());
  f = LittleFS.open(PLANTS_FILE, "w");
  if (f) { serializeJson(arr, f); f.close(); server.send(200, "text/plain", "OK"); }
  else server.send(500, "text/plain", "File error");
}

void handlePlantsDelete() {
  if (server.method() != HTTP_DELETE) { server.send(405, "text/plain", "Method not allowed"); return; }
  String name = server.arg("name");
  DynamicJsonDocument plantsDoc(4096);
  File f = LittleFS.open(PLANTS_FILE, "r");
  JsonArray arr = plantsDoc.to<JsonArray>();
  if (f) { deserializeJson(plantsDoc, f); f.close(); arr = plantsDoc.as<JsonArray>(); }
  if (!arr) arr = plantsDoc.to<JsonArray>();

  DynamicJsonDocument filtered(4096);
  JsonArray newArr = filtered.to<JsonArray>();
  for (JsonObject p : arr) if (p["name"].as<String>() != name) newArr.add(p);
  
  f = LittleFS.open(PLANTS_FILE, "w"); if (f) { serializeJson(filtered, f); f.close(); }
  server.send(200, "text/plain", "OK");
}
