.plant-card .del-btn { position: absolute; top: 8px; right: 8px; background: transparent; border: none; color: var(--text2); cursor: pointer; padding: 4px 6px; border-radius: 4px; font-size: 12px; transition: 0.2s; }
.plant-card .del-btn:hover { background: rgba(239,68,68,0.1); color: var(--danger); }
.custom-form { border-top: 1px solid var(--border); padding-top: 16px; margin-top: 16px; }
.custom-form h3 { font-size: 16px; margin-bottom: 12px; color: var(--text); }
.range-row { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
.range-row input { width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg); color: var(--text); text-align: center; }
.error-msg { color: var(--danger); font-size: 12px; margin-bottom: 8px; min-height: 16px; }
.btn-primary { width: 100%; padding: 12px; background: var(--primary); color: #fff; border: none; border-radius: 12px; font-weight: 600; cursor: pointer; font-size: 14px; transition: background 0.2s; }
.btn-primary:hover { background: var(--primary-dark); }
.btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
@media (max-width: 500px) { .plant-grid { grid-template-columns: 1fr; } }
.value-red { color: var(--danger) !important; }
@keyframes pulseAlert { 0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); } 50% { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); } }
.metric-alert { animation: pulseAlert 1.5s infinite; border-color: var(--danger) !important; }
</style>
</head>
<body>

<div id="authView" class="overlay">
  <div class="overlay-card">
    <h2 id="authTitle">Вход</h2>
    <div class="form-group"><label>Имя пользователя</label><input type="text" id="authUser" class="form-input" autocomplete="username"></div>
    <div class="form-group"><label>Пароль</label><input type="password" id="authPass" class="form-input" autocomplete="current-password"></div>
    <div class="error-msg" id="authError"></div>
    <button id="authBtn" class="btn-primary">Войти</button>
    <div class="auth-toggle" id="authToggle">Нет аккаунта? Зарегистрироваться</div>
  </div>
</div>

<div id="plantView" class="overlay">
  <div class="overlay-card">
    <h2>Выберите растение</h2>
    <div id="plantGrid" class="plant-grid"></div>
    <div class="custom-form">
      <h3>Добавить своё</h3>
      <div class="form-group"><label>Название</label><input type="text" id="custName" class="form-input" placeholder="Уникальное имя"></div>
      <div class="form-group"><label>Температура (мин - макс, °C)</label><div class="range-row"><input type="number" id="custTempMin"><span>-</span><input type="number" id="custTempMax"></div></div>
      <div class="form-group"><label>Влажность (мин - макс, %)</label><div class="range-row"><input type="number" id="custHumMin"><span>-</span><input type="number" id="custHumMax"></div></div>
      <div class="form-group"><label>Влажность почвы (мин - макс, %)</label><div class="range-row"><input type="number" id="custSoilMin"><span>-</span><input type="number" id="custSoilMax"></div></div>
      <div class="form-group"><label>Давление (мин - макс, мм)</label><div class="range-row"><input type="number" id="custPresMin"><span>-</span><input type="number" id="custPresMax"></div></div>
      <div class="error-msg" id="plantError"></div>
      <button id="savePlantBtn" class="btn-primary">Сохранить и применить</button>
    </div>
  </div>
</div>

<button class="theme-toggle" id="themeBtn" title="Переключить тему">◑</button>
<header>
Мониторинг растений
<span class="status" id="timeStatus">--:--</span>
<span class="sync-status" id="syncStatus">●</span>
<span class="action-btn" id="changePlantBtn" style="display:none;">Сменить растение</span>
<span class="action-btn logout-btn" id="logoutBtn" style="display:none;">Выйти</span>
</header>
<div class="tabs">
<button class="tab active" data-tab="main">Показатели</button>
<button class="tab" data-tab="charts">Графики</button>
</div>
<div class="container">
<div id="tab-main" class="content active">
<div class="metrics-grid">
<div class="metric-card"><div class="metric-label">Температура</div><div class="metric-value" id="temp">--</div><div class="metric-unit">°C</div></div>
<div class="metric-card"><div class="metric-label">Влажность воздуха</div><div class="metric-value" id="hum">--</div><div class="metric-unit">%</div></div>
<div class="metric-card"><div class="metric-label">Влажность почвы</div><div class="metric-value" id="soil">--</div><div class="metric-unit">%</div></div>
<div class="metric-card"><div class="metric-label">Атм. давление</div><div class="metric-value" id="pressure">--</div><div class="metric-unit">мм рт.ст.</div></div>
</div>
<div class="history-panel">
<div class="history-header"><div class="history-title">История измерений</div>
<div class="filter-group">
<button class="filter-btn active" data-period="0" data-limit="20">Посл. 20</button>
<button class="filter-btn" data-period="86400" data-limit="0">1 день</button>
<button class="filter-btn" data-period="604800" data-limit="0">7 дней</button>
<button class="filter-btn" data-period="2592000" data-limit="0">Месяц</button>
<button class="filter-btn" id="historyDateBtn">Дата</button>
<button class="filter-btn danger" id="clearBtn" title="Очистить историю">X</button>
</div></div>
<div class="custom-range" id="historyCustomRange" style="display:none; margin-bottom:10px;">
<input type="datetime-local" id="historyStartDate"><input type="datetime-local" id="historyEndDate">
<button class="filter-btn active" id="historyApplyBtn">Применить</button><button class="filter-btn" id="historyCancelBtn">Отмена</button>
</div>
<div class="history-list" id="historyList"><div class="loading">Загрузка данных...</div></div>
</div></div>
<div id="tab-charts" class="content">
<div class="chart-panel">
<div class="chart-header"><div><span class="chart-title">Динамика показателей</span><span class="chart-mode-indicator" id="chartModeIndicator">Режим: один параметр</span></div>
<div class="chart-filters">
<button class="chart-filter active" data-period="0" data-limit="20">Посл. 20</button>
<button class="chart-filter" data-period="86400" data-limit="0">1 день</button>
<button class="chart-filter" data-period="604800" data-limit="0">7 дней</button>
<button class="chart-filter" data-period="2592000" data-limit="0">Месяц</button>
<button class="chart-filter" id="chartDateBtn">Дата</button>
</div></div>
<div class="custom-range" id="chartCustomRange" style="display:none; margin-bottom:10px;">
<input type="datetime-local" id="chartStartDate"><input type="datetime-local" id="chartEndDate">
<button class="filter-btn active" id="chartApplyBtn">Применить</button><button class="filter-btn" id="chartCancelBtn">Отмена</button>
</div>
<div class="chart-container"><canvas id="chart"></canvas><div class="chart-tooltip" id="tooltip"><div class="tooltip-time"></div></div><div class="y-axis-label" id="yAxisLabel"></div><div class="y-axis-values" id="yAxisValues"></div></div>
<div class="chart-legend" id="legend">
<div class="legend-item active" data-metric="all"><span class="legend-dot" style="background:linear-gradient(135deg,#ef4444,#3b82f6,#22c55e,#a855f7)"></span>Все параметры</div>
<div class="legend-item" data-metric="temp"><span class="legend-dot" style="background:#ef4444"></span>Температура</div>
<div class="legend-item" data-metric="hum"><span class="legend-dot" style="background:#3b82f6"></span>Влажность</div>
<div class="legend-item" data-metric="soil"><span class="legend-dot" style="background:#22c55e"></span>Почва</div>
<div class="legend-item" data-metric="pressure"><span class="legend-dot" style="background:#a855f7"></span>Давление</div>
</div></div></div>
</div>
<script>
let chartData=[], currentHistoryPeriod=0, currentHistoryLimit=20, currentChartPeriod=0, currentChartLimit=20;
let visibleMetrics={temp:true,hum:true,soil:true,pressure:true}, currentChartMode='all', serverTimeOffset=0;
let historyCustomStart=0,historyCustomEnd=0,chartCustomStart=0,chartCustomEnd=0;
const UPDATE_INTERVAL=10000; let plantConfig=null;

document.addEventListener('DOMContentLoaded',()=>{
  initTheme();initTabs();initHistoryFilters();initChartFilters();initLegend();initClearButton();
  initHistoryCustomRange();initChartCustomRange();initChart();checkAuth();
  document.getElementById('authBtn').addEventListener('click',handleAuthAction);
  document.getElementById('authToggle').addEventListener('click',toggleAuthMode);
  document.getElementById('savePlantBtn').addEventListener('click',saveCustomPlant);
  document.getElementById('changePlantBtn').addEventListener('click',showPlantView);
  document.getElementById('logoutBtn').addEventListener('click',handleLogout);
});

let isRegisterMode=false;
function checkAuth(){
  if(sessionStorage.getItem('logged')==='true'){
    document.getElementById('authView').style.display='none';
    document.getElementById('changePlantBtn').style.display='inline';
    document.getElementById('logoutBtn').style.display='inline';
    loadPlants();
  }else document.getElementById('authView').style.display='flex';
}
function toggleAuthMode(){
  isRegisterMode=!isRegisterMode;
  document.getElementById('authTitle').textContent=isRegisterMode?'Регистрация':'Вход';
  document.getElementById('authBtn').textContent=isRegisterMode?'Зарегистрироваться':'Войти';
  document.getElementById('authToggle').textContent=isRegisterMode?'Уже есть аккаунт? Войти':'Нет аккаунта? Зарегистрироваться';
  document.getElementById('authError').textContent='';
}
async function handleAuthAction(){
  const u=document.getElementById('authUser').value.trim(),p=document.getElementById('authPass').value;
  const errEl=document.getElementById('authError');
  if(!u||!p){errEl.textContent='Заполните все поля';return;}
  errEl.textContent='Проверка...';const btn=document.getElementById('authBtn');btn.disabled=true;
  try{
    const res=await fetch(isRegisterMode?'/auth/register':'/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:u,password:p})});
    if(res.ok){sessionStorage.setItem('logged','true');sessionStorage.setItem('user',u);checkAuth();}
    else errEl.textContent=res.status===409?'Имя занято':'Неверные данные';
  }catch(e){errEl.textContent='Ошибка сети';}finally{btn.disabled=false;}
}
function handleLogout(){sessionStorage.removeItem('logged');sessionStorage.removeItem('user');plantConfig=null;location.reload();}

function showPlantView(){document.getElementById('plantView').style.display='flex';loadPlants();}
async function loadPlants(){
  const grid=document.getElementById('plantGrid');grid.innerHTML='<div class="loading">Загрузка...</div>';
  try{
    const res=await fetch('/plants/load');const plants=await res.json();grid.innerHTML='';
    if(!plants.length){grid.innerHTML='<div class="history-empty">Нет сохранённых растений</div>';return;}
    plants.forEach(p=>{
      const div=document.createElement('div');
      div.className='plant-card'+(plantConfig&&plantConfig.name===p.name?' selected':'');
      div.dataset.name=p.name;
      div.innerHTML=`<strong>${p.displayName||p.name}</strong><span>T:${p.temp[0]}-${p.temp[1]}|H:${p.hum[0]}-${p.hum[1]}</span>${p.name!=='Monstera'&&p.name!=='Cactus'?'<button class="del-btn">Удалить</button>':''}`;
      div.addEventListener('click',(e)=>{if(e.target.classList.contains('del-btn'))return;selectPlant(p);});
      div.querySelector('.del-btn')?.addEventListener('click',(e)=>{e.stopPropagation();deletePlant(p.name,div);});
      grid.appendChild(div);
    });
  }catch(e){grid.innerHTML='<div class="history-empty">Ошибка</div>';}
}
function selectPlant(p){
  document.querySelectorAll('.plant-card').forEach(c=>c.classList.remove('selected'));
  const target=document.querySelector(`.plant-card[data-name="${p.name}"]`);
  if(target)target.classList.add('selected');
  plantConfig=p;localStorage.setItem('selectedPlant',JSON.stringify(p));
  document.getElementById('plantView').style.display='none';loadData();
}
async function deletePlant(name,el){
  if(!confirm('Удалить "'+name+'"?'))return;
  try{await fetch('/plants/delete?name='+encodeURIComponent(name),{method:'DELETE'});el.remove();if(plantConfig?.name===name)plantConfig=null;}
  catch(e){alert('Ошибка удаления');}
}
async function saveCustomPlant(){
  const v=id=>{let x=parseFloat(document.getElementById(id).value);return isNaN(x)?null:x;};
  const tMin=v('custTempMin'),tMax=v('custTempMax'),hMin=v('custHumMin'),hMax=v('custHumMax');
  const sMin=v('custSoilMin'),sMax=v('custSoilMax'),pMin=v('custPresMin'),pMax=v('custPresMax');
  const err=document.getElementById('plantError');
  if(tMin===null||tMax===null){err.textContent='Укажите температуру';return;}
  if(tMin>=tMax){err.textContent='Температура: мин < макс';return;}
  try{[hMin,hMax,sMin,sMax,pMin,pMax].forEach((val,i)=>{
    const names=['Влажность','Влажность почвы','Давление'];
    if(val===null){err.textContent=`Укажите ${names[Math.floor(i/2)]}`;throw'stop';}
    if(val<0){err.textContent=`${names[Math.floor(i/2)]} не может быть отрицательной`;throw'stop';}
  });}catch(e){if(e==='stop')return;}
  if(hMin>=hMax){err.textContent='Влажность: мин < макс';return;}
  if(sMin>=sMax){err.textContent='Почва: мин < макс';return;}
  if(pMin>=pMax){err.textContent='Давление: мин < макс';return;}
  const name=document.getElementById('custName').value.trim().replace(/[^a-zA-Zа-яА-Я0-9\s_-]/g,'');
  if(!name){err.textContent='Введите название';return;}
  const btn=document.getElementById('savePlantBtn');btn.disabled=true;err.textContent='';
  const cfg={name,displayName:name,temp:[tMin,tMax],hum:[hMin,hMax],soil:[sMin,sMax],press:[pMin,pMax]};
  try{const res=await fetch('/plants/save',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(cfg)});
    if(res.ok)selectPlant(cfg);else err.textContent=res.status===409?'Имя занято':'Ошибка сохранения';
  }catch(e){err.textContent='Ошибка сети';}finally{btn.disabled=false;}
}

async function syncTimeWithServer(){try{const res=await fetch('/time?t='+Date.now());const s=await res.text();const now=new Date();if(s&&!s.startsWith('UP')){const p=s.split(' ');if(p.length>=2){const[d,t]=p;const[day,m,y]=d.split('.');const[h,mi,sc]=t.split(':');const sd=new Date('20'+y+'-'+m+'-'+day+'T'+h+':'+mi+':'+sc);serverTimeOffset=sd.getTime()-now.getTime();document.getElementById('timeStatus').textContent=s;document.getElementById('syncStatus').className='sync-status';}}else document.getElementById('syncStatus').className='sync-status error';}catch(e){document.getElementById('syncStatus').className='sync-status error';}}
function initTheme(){const s=localStorage.getItem('theme');if(s==='dark')document.documentElement.setAttribute('data-theme','dark');document.getElementById('themeBtn').addEventListener('click',()=>{const h=document.documentElement;const d=h.getAttribute('data-theme')==='dark';if(d){h.removeAttribute('data-theme');localStorage.setItem('theme','light');}else{h.setAttribute('data-theme','dark');localStorage.setItem('theme','dark');}if(document.getElementById('tab-charts').classList.contains('active'))drawChart();});}
function initTabs(){document.querySelectorAll('.tab').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));document.querySelectorAll('.content').forEach(x=>x.classList.remove('active'));b.classList.add('active');document.getElementById('tab-'+b.dataset.tab).classList.add('active');if(b.dataset.tab==='charts')setTimeout(drawChart,100);});});}
function initHistoryFilters(){document.querySelectorAll('.history-panel .filter-btn[data-period]').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.history-panel .filter-btn[data-period]').forEach(x=>x.classList.remove('active'));b.classList.add('active');currentHistoryPeriod=parseInt(b.dataset.period);currentHistoryLimit=parseInt(b.dataset.limit);historyCustomStart=0;historyCustomEnd=0;document.getElementById('historyCustomRange').style.display='none';loadHistory();});});}
function initChartFilters(){document.querySelectorAll('.chart-panel .chart-filter[data-period]').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.chart-panel .chart-filter[data-period]').forEach(x=>x.classList.remove('active'));b.classList.add('active');currentChartPeriod=parseInt(b.dataset.period);currentChartLimit=parseInt(b.dataset.limit);chartCustomStart=0;chartCustomEnd=0;document.getElementById('chartCustomRange').style.display='none';loadChartData();});});}
function initHistoryCustomRange(){document.getElementById('historyDateBtn').addEventListener('click',()=>{document.querySelectorAll('.history-panel .filter-btn[data-period]').forEach(b=>b.classList.remove('active'));document.getElementById('historyDateBtn').classList.add('active');document.getElementById('historyCustomRange').style.display='flex';const n=new Date();n.setMinutes(n.getMinutes()-n.getTimezoneOffset());document.getElementById('historyEndDate').value=n.toISOString().slice(0,16);document.getElementById('historyStartDate').value=new Date(n.getTime()-24*60*60*1000).toISOString().slice(0,16);});document.getElementById('historyApplyBtn').addEventListener('click',()=>{const s=document.getElementById('historyStartDate').value,e=document.getElementById('historyEndDate').value;if(s&&e){historyCustomStart=Math.floor(new Date(s).getTime()/1000);historyCustomEnd=Math.floor(new Date(e).getTime()/1000);currentHistoryPeriod=0;currentHistoryLimit=0;loadHistory();document.getElementById('historyCustomRange').style.display='none';}});document.getElementById('historyCancelBtn').addEventListener('click',()=>{document.getElementById('historyCustomRange').style.display='none';document.querySelectorAll('.history-panel .filter-btn[data-period]').forEach(b=>b.classList.remove('active'));document.querySelector('.history-panel .filter-btn[data-period="0"]').classList.add('active');currentHistoryPeriod=0;currentHistoryLimit=20;historyCustomStart=0;historyCustomEnd=0;loadHistory();});}
function initChartCustomRange(){document.getElementById('chartDateBtn').addEventListener('click',()=>{document.querySelectorAll('.chart-panel .chart-filter[data-period]').forEach(b=>b.classList.remove('active'));document.getElementById('chartDateBtn').classList.add('active');document.getElementById('chartCustomRange').style.display='flex';const n=new Date();n.setMinutes(n.getMinutes()-n.getTimezoneOffset());document.getElementById('chartEndDate').value=n.toISOString().slice(0,16);document.getElementById('chartStartDate').value=new Date(n.getTime()-24*60*60*1000).toISOString().slice(0,16);});document.getElementById('chartApplyBtn').addEventListener('click',()=>{const s=document.getElementById('chartStartDate').value,e=document.getElementById('chartEndDate').value;if(s&&e){chartCustomStart=Math.floor(new Date(s).getTime()/1000);chartCustomEnd=Math.floor(new Date(e).getTime()/1000);currentChartPeriod=0;currentChartLimit=0;loadChartData();document.getElementById('chartCustomRange').style.display='none';}});document.getElementById('chartCancelBtn').addEventListener('click',()=>{document.getElementById('chartCustomRange').style.display='none';document.querySelectorAll('.chart-panel .chart-filter[data-period]').forEach(b=>b.classList.remove('active'));document.querySelector('.chart-panel .chart-filter[data-period="0"]').classList.add('active');currentChartPeriod=0;currentChartLimit=20;chartCustomStart=0;chartCustomEnd=0;loadChartData();});}
function initLegend(){document.querySelectorAll('.legend-item').forEach(i=>{i.addEventListener('click',()=>{document.querySelectorAll('.legend-item').forEach(x=>x.classList.remove('active'));i.classList.add('active');const m=i.dataset.metric;if(m==='all'){currentChartMode='all';visibleMetrics={temp:true,hum:true,soil:true,pressure:true};document.getElementById('chartModeIndicator').classList.remove('visible');document.getElementById('yAxisLabel').style.display='none';document.getElementById('yAxisValues').innerHTML='';}else{currentChartMode=m;visibleMetrics={temp:false,hum:false,soil:false,pressure:false};visibleMetrics[m]=true;document.getElementById('chartModeIndicator').classList.add('visible');const l={temp:'°C',hum:'%',soil:'%',pressure:'мм'};const el=document.getElementById('yAxisLabel');el.textContent=l[m]||'';el.style.color=getMetricStyle(m).color;el.style.display='block';}drawChart();});});}
function initClearButton(){document.getElementById('clearBtn').addEventListener('click',async()=>{if(!confirm('Удалить всю историю?'))return;try{await fetch('/clear',{method:'POST'});loadHistory();if(document.getElementById('tab-charts').classList.contains('active'))loadChartData();}catch(e){alert('Ошибка');}});}
async function loadData(){await Promise.all([fetchMetrics(),loadHistory()]);if(document.getElementById('tab-charts').classList.contains('active'))await loadChartData();}
async function fetchMetrics(){try{const r=await fetch('/data?t='+Date.now());updateMetrics(await r.json());syncTimeWithServer();}catch(e){console.log('Ошибка');}}
function updateMetrics(d){const list=[{id:'temp',key:'temp',range:plantConfig?.temp},{id:'hum',key:'humidity',range:plantConfig?.hum},{id:'soil',key:'soil',range:plantConfig?.soil},{id:'pressure',key:'pressure',range:plantConfig?.press}];list.forEach(m=>{const el=document.getElementById(m.id);const val=d[m.key];el.textContent=val??'--';const card=el.parentElement;card.classList.remove('metric-alert');el.classList.remove('value-red');if(plantConfig&&val!==null&&m.range&&(val<m.range[0]||val>m.range[1])){card.classList.add('metric-alert');el.classList.add('value-red');}});}
async function loadHistory(){const l=document.getElementById('historyList');l.innerHTML='<div class="loading">Загрузка...</div>';try{let u='/hist?period='+currentHistoryPeriod+'&limit='+currentHistoryLimit;if(historyCustomStart>0&&historyCustomEnd>0)u+='&start='+historyCustomStart+'&end='+historyCustomEnd;u+='&t='+Date.now();chartData=await (await fetch(u)).json();renderHistory(chartData);}catch(e){l.innerHTML='<div class="history-empty">Ошибка</div>';}}
function renderHistory(data){const l=document.getElementById('historyList');if(!data||!data.length){l.innerHTML='<div class="history-empty">Нет данных</div>';return;}let h='';data.slice().reverse().forEach(i=>{h+='<div class="history-item"><span class="history-time">'+(i.time||'--:--:--')+'</span><div class="history-values"><span class="val-temp">T:'+(i.temp!=null?i.temp:'-')+'°C</span><span class="val-hum">H:'+(i.hum!=null?i.hum:'-')+'%</span><span class="val-soil">S:'+(i.soil!=null?i.soil:'-')+'%</span><span class="val-press">P:'+(i.pressure!=null?i.pressure:'-')+'мм</span></div></div>';});l.innerHTML=h;}
async function loadChartData(){try{let u='/hist?period='+currentChartPeriod+'&limit='+currentChartLimit;if(chartCustomStart>0&&chartCustomEnd>0)u+='&start='+chartCustomStart+'&end='+chartCustomEnd;u+='&t='+Date.now();chartData=await (await fetch(u)).json();drawChart();}catch(e){console.log('Ошибка графика');}}
let chartCtx,chartCanvas;function initChart(){chartCanvas=document.getElementById('chart');chartCtx=chartCanvas.getContext('2d');chartCanvas.addEventListener('mousemove',handleChartHover);chartCanvas.addEventListener('mouseleave',hideTooltip);chartCanvas.addEventListener('touchmove',(e)=>{e.preventDefault();handleChartHover(e);},{passive:false});window.addEventListener('resize',()=>{if(document.getElementById('tab-charts').classList.contains('active'))drawChart();});}
function drawChart(){if(!chartCtx||!chartData||chartData.length<2){drawEmptyChart();return;}const dpr=window.devicePixelRatio||1;const rect=chartCanvas.getBoundingClientRect();chartCanvas.width=rect.width*dpr;chartCanvas.height=rect.height*dpr;chartCtx.scale(dpr,dpr);const W=rect.width,H=rect.height,P={t:25,r:40,b:40,l:45},cW=W-P.l-P.r,cH=H-P.t-P.b;chartCtx.clearRect(0,0,W,H);const active=currentChartMode==='all'?Object.keys(visibleMetrics).filter(k=>visibleMetrics[k]):[currentChartMode];if(!active.length){drawEmptyChart();return;}const ranges=calculateRanges(chartData,active);drawGrid(P,cW,cH,ranges,W,H,active);drawYAxisValues(P,cH,ranges,active);const lines={};active.forEach(k=>{lines[k]=drawLine(chartData,k,ranges[k],P,cW,cH,getMetricStyle(k));});chartCanvas._lines=lines;chartCanvas._params={P,cW,cH,ranges,active};}
function calculateRanges(data,active){const ranges={};const info={temp:{key:'temp',defaultMin:10,defaultMax:35},hum:{key:'hum',defaultMin:0,defaultMax:100},soil:{key:'soil',defaultMin:0,defaultMax:100},pressure:{key:'pressure',defaultMin:740,defaultMax:770}};active.forEach(m=>{const i=info[m];let mn=Infinity,mx=-Infinity;data.forEach(d=>{const v=d[i.key];if(v!=null){mn=Math.min(mn,v);mx=Math.max(mx,v);}});if(mn===Infinity){mn=i.defaultMin;mx=i.defaultMax;}if(mn===mx){mn-=1;mx+=1;}const p=(mx-mn)*0.1;ranges[m]={min:mn-p,max:mx+p,key:i.key};});return ranges;}
function getMetricStyle(k){const s={temp:{color:'#ef4444',width:2.5},hum:{color:'#3b82f6',width:2.5},soil:{color:'#22c55e',width:2.5},pressure:{color:'#a855f7',width:2,dash:[5,3]}};return s[k]||{color:'#6b7280',width:2};}
